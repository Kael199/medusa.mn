# --- Сервер ---
PORT=3000
NODE_ENV=production
SESSION_SECRET=маш_урт_нууц_үг_энд_өөрчилнө_123456

# --- Таны сайтын хаяг (QPay callback-д хэрэгтэй) ---
SITE_URL=https://тансайт.mn

# --- Admin бүртгэл ---
# Эхний удаа сервер асаахад энэ мэдээллээр admin бүртгэл үүснэ
ADMIN_EMAIL=tuvshinbayr1145@gmail.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=өөрийн_нууц_үг_ЭНД

# --- QPay тохиргоо ---
# merchant.qpay.mn дээр бүртгүүлснийхээ дараа авна
